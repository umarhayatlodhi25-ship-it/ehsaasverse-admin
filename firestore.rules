rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Text Shayari: Everyone can read, only admin can write
    match /text_shayari/{document=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "lodhitools@gmail.com";
    }

    // Categories: Everyone can read, only admin can write
    match /categories/{document=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "lodhitools@gmail.com";
    }

    // Feedback: Everyone can create, only admin can read/manage
    match /feedback/{document=**} {
      allow create: if true;
      allow read, update, delete: if request.auth != null && request.auth.token.email == "lodhitools@gmail.com";
    }

    // Legacy collection support (if needed)
    match /verse_official_v1/{document=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "lodhitools@gmail.com";
    }
  }
}
